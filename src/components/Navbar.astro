---
---
<nav>
	<a href="/" class="nav-logo">
		<span class="nav-logo-accent">鋅</span> STUDIO ZINC
	</a>
	<div class="nav-right">
		<button class="tog" id="langBtn"><span class="l-zh">EN</span><span class="l-en">中文</span></button>
		<button class="tog" id="themeBtn"><span class="t-dark">☀</span><span class="t-light">☾</span></button>
		<button class="nav-hamburger" id="hamburger" aria-label="Menu">
			<span></span><span></span><span></span>
		</button>
	</div>
</nav>

<div class="nav-drawer" id="drawer">
	<a href="/#work" data-zh="作品" data-en="Work" onclick="closeDrawer()">作品</a>
	<a href="/#about" data-zh="關於" data-en="About" onclick="closeDrawer()">關於</a>
	<a href="/#contact" data-zh="聯絡" data-en="Contact" onclick="closeDrawer()">聯絡</a>
	<div class="drawer-bottom">
		<button class="tog" id="langBtn2"><span class="l-zh">EN</span><span class="l-en">中文</span></button>
		<button class="tog" id="themeBtn2"><span class="t-dark">☀</span><span class="t-light">☾</span></button>
		<a href="/#contact" class="btn-cta" onclick="closeDrawer()" data-zh="預約諮詢" data-en="Book Consultation">預約諮詢</a>
	</div>
</div>

<script>
	// Burger Menu
	const burger = document.getElementById('hamburger');
	const drawer = document.getElementById('drawer');

	function closeDrawer() {
		if (!drawer || !burger) return;
		drawer.classList.remove('open');
		burger.classList.remove('open');
		document.body.style.overflow = '';
	}

	if (burger && drawer) {
		burger.addEventListener('click', () => {
			const open = drawer.classList.toggle('open');
			burger.classList.toggle('open', open);
			document.body.style.overflow = open ? 'hidden' : '';
		});
	}

	// Make closeDrawer globally available for onclick
	(window as any).closeDrawer = closeDrawer;

	// Lang Toggle Logic (Local to component or global?)
	function applyLang(lang: string) {
		document.documentElement.setAttribute('data-lang', lang);
		document.documentElement.setAttribute('lang', lang === 'zh' ? 'zh-TW' : 'en');
		document.querySelectorAll('[data-zh][data-en]').forEach((el: any) => {
			el.innerHTML = el.getAttribute('data-' + lang);
		});
		try { localStorage.setItem('studiozinc-lang', lang); } catch (e) { }
	}

	['langBtn', 'langBtn2'].forEach(id => {
		const btn = document.getElementById(id);
		if (btn) btn.addEventListener('click', () => {
			applyLang(document.documentElement.getAttribute('data-lang') === 'zh' ? 'en' : 'zh');
		});
	});

	// Theme Toggle Logic
	function applyTheme(t: string) {
		document.documentElement.setAttribute('data-theme', t);
		try { localStorage.setItem('studiozinc-theme', t); } catch (e) { }
	}

	['themeBtn', 'themeBtn2'].forEach(id => {
		const btn = document.getElementById(id);
		if (btn) btn.addEventListener('click', () => {
			applyTheme(document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark');
		});
	});
</script>
