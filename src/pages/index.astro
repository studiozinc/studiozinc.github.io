---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Taipei Bilingual Designer 台北雙語設計師 | STUDIO ZINC">
	<Navbar />
	
	<div class="snap-container" id="snapContainer">
		<!-- HERO -->
		<section class="snap-section hero" id="hero">
			<div class="hero-grid"></div>
			<div class="hero-lava" id="heroLava">
				<div class="hero-lava-1"></div>
				<div class="hero-lava-2"></div>
				<div class="hero-lava-3"></div>
			</div>
			<div class="hero-content">
				<h1 class="hero-headline">
					<span class="line" data-zh="讓你的品牌" data-en="Your brand,">讓你的品牌</span>
					<span class="line" data-zh="說國際語言" data-en="global-ready.">說國際語言</span>
				</h1>
				<div class="hero-actions">
					<a href="#work" class="btn-primary" data-zh="看作品 →" data-en="View Work →">看作品 →</a>
				</div>
			</div>
			<div class="hero-bottom">
				<div class="hero-stat">
					<div class="hero-stat-num">15<span>+</span></div>
					<div class="hero-stat-label" data-zh="年資歷" data-en="Years Experience">年資歷</div>
				</div>
				<div class="hero-stat">
					<div class="hero-stat-num">50<span>+</span></div>
					<div class="hero-stat-label" data-zh="成功專案" data-en="Projects Delivered">成功專案</div>
				</div>
				<div class="hero-avail">
					<div class="pulse"></div>
					<span data-zh="接受新案" data-en="Available for Projects">接受新案</span>
				</div>
			</div>
		</section>

		<!-- WORK -->
		<section class="snap-section free" id="work">
			<div class="work-section">
				<div class="section-header reveal">
					<div>
						<h2 class="section-title" data-zh="精選作品" data-en="Selected Work">精選作品</h2>
					</div>
				</div>
				<div class="work-grid" id="workGrid">
					<!-- Data injection will handle this -->
				</div>
			</div>
		</section>

		<!-- ABOUT -->
		<section class="snap-section free" id="about">
			<div class="about-section">
				<div class="about-left">
					<div class="svc-header reveal" data-zh="關於我" data-en="About Me">關於我</div>
					<div class="about-quote reveal" data-zh="工程師出身，印刷起家。<strong>我用解決問題的腦袋做設計，用做過生產的雙手交付作品。</strong>"
						data-en="Engineer turned designer. <strong>I bring a problem-solver's mind and a maker's hands to every project.</strong>">
						工程師出身，印刷起家。<strong>我用解決問題的腦袋做設計，用做過生產的雙手交付作品。</strong>
					</div>
					<p class="about-p reveal"
						data-zh="我的設計之路不是從美術系開始的——而是從一間印刷工作室。在那之前，我是一名工程師。正是這段經歷讓我理解：好的設計不只是好看，它要能落地、能印刷、能在螢幕上跑、能幫客戶解決真正的問題。十五年來，我服務過跨國企業、本地小店、新創公司和非營利組織。無論規模大小，每個案子我都當成自己的事來做。"
						data-en="I didn't start in design school — I started in engineering. Then I ran a print shop, where I learned that great design means nothing if it can't be produced, delivered, and put to work. That hands-on foundation shaped everything I do today. Over fifteen years, I've worked with Fortune 500 companies, local businesses, startups, and nonprofits. Big or small, every project gets the same level of care — because your brand is your livelihood, and I don't take that lightly.">
						我的設計之路不是從美術系開始的——而是從一間印刷工作室。在那之前，我是一名工程師。正是這段經歷讓我理解：好的設計不只是好看，它要能落地、能印刷、能在螢幕上跑、能幫客戶解決真正的問題。十五年來，我服務過跨國企業、本地小店、新創公司和非營利組織。無論規模大小，每個案子我都當成自己的事來做。
					</p>
					<div class="about-closing reveal" data-zh="你不只是在找一個設計師——你在找一個真正在乎成果的人。"
						data-en="You're not just hiring a designer — you're getting someone who genuinely cares how it turns out.">
						你不只是在找一個設計師——你在找一個真正在乎成果的人。
					</div>
				</div>
				<div class="about-right">
					<div class="svc-header reveal" data-zh="服務項目" data-en="Services">服務項目</div>
					<div class="svc-list">
						<div class="svc reveal"><span class="svc-n">01</span><div class="svc-body"><span class="svc-name" data-zh="品牌識別" data-en="Brand Identity">品牌識別</span><span class="svc-desc" data-zh="標誌 · 視覺系統" data-en="Logo Design · Visual Identity System">標誌 · 視覺系統</span></div></div>
						<div class="svc reveal"><span class="svc-n">02</span><div class="svc-body"><span class="svc-name" data-zh="網站設計" data-en="Web Design">網站設計</span><span class="svc-desc" data-zh="設計 · 建置 · 維護" data-en="Web Design · Front-end Build · Ongoing Updates">設計 · 建置 · 維護</span></div></div>
						<div class="svc reveal"><span class="svc-n">03</span><div class="svc-body"><span class="svc-name" data-zh="印刷與編輯" data-en="Print & Editorial">印刷與編輯</span><span class="svc-desc" data-zh="雜誌封面 · 海報 · 書籍 · 服裝印刷諮詢" data-en="Print Design · Editorial Layout · Posters · TShirt Printing">雜誌封面 · 海報 · 書籍 · 服裝印刷諮詢</span></div></div>
						<div class="svc reveal"><span class="svc-n">04</span><div class="svc-body"><span class="svc-name" data-zh="社群媒體視覺" data-en="Social Media">社群媒體視覺</span><span class="svc-desc" data-zh="圖像 · 模板 · 內容" data-en="Social Graphics · Template Systems · Content Layout">圖像 · 模板 · 內容</span></div></div>
						<div class="svc reveal"><span class="svc-n">05</span><div class="svc-body"><span class="svc-name" data-zh="行動應用開發" data-en="Mobile App Development">行動應用開發</span><span class="svc-desc" data-zh="介面設計 · 應用程式" data-en="UI/UX Design · App Development">介面設計 · 應用程式</span></div></div>
						<div class="svc reveal"><span class="svc-n">06</span><div class="svc-body"><span class="svc-name" data-zh="影片剪輯" data-en="Video Editing">影片剪輯</span><span class="svc-desc" data-zh="品牌影片 · 剪輯" data-en="Brand Film · Edit">品牌影片 · 剪輯</span></div></div>
					</div>
				</div>
			</div>
			<div class="faq-section">
				<div class="faq-inner">
					<div class="svc-header reveal" data-zh="常見問題" data-en="FAQ">常見問題</div>
					<div class="faq-list">
						<details class="faq-item reveal"><summary class="faq-summary" data-zh="你提供英文溝通與中英雙語交付嗎？" data-en="Do you offer English communication and bilingual deliverables?">你提供英文溝通與中英雙語交付嗎？</summary><p class="about-p faq-answer" data-zh="可以。我提供英文會議與書面溝通，並可交付中英雙語版本的設計檔與文件。" data-en="Yes. I offer English meetings and written communication, and can deliver bilingual assets.">可以。我提供英文會議與書面溝通，並可交付中英雙語版本的設計檔與文件。</p></details>
						<!-- More FAQs... -->
					</div>
				</div>
			</div>
		</section>

		<!-- CONTACT -->
		<section class="snap-section free" id="contact" style="position:relative;">
			<div class="footer-lava" aria-hidden="true"><div class="footer-lava-1"></div><div class="footer-lava-2"></div></div>
			<div class="contact-section" style="position:relative; z-index:1; grid-template-columns: 1fr;">
				<div class="contact-left" style="border-right: none;">
					<h2 class="contact-headline reveal" data-zh="讓我們一起規劃你的下一個專案。" data-en="Let's plan your next project together.">讓我們一起規劃你的下一個專案。</h2>
					<a href="mailto:hello@studiozinc.com" class="contact-email-display reveal" style="margin-bottom: 2.5rem;">hello@studiozinc.com</a>
					<div class="contact-info reveal">
						<div><div class="ci-label" data-zh="地點" data-en="Location">地點</div><div class="ci-val">大安區，台北<br>Taipei, Taiwan</div></div>
						<div><div class="ci-label" data-zh="時區" data-en="Time Zone">時區</div><div class="ci-val">GMT+8 CST</div></div>
					</div>
				</div>
				<Footer />
			</div>
		</section>
	</div>

	<div class="pj-overlay" id="pjOverlay"></div>
	<div class="pj-modal" id="pjModal" role="dialog" aria-modal="true">
		<button class="pj-close" id="pjClose" aria-label="Close">✕</button>
		<div id="pjContent"></div>
	</div>

	<script>
		// Project Data & Modal Logic
		const PROJECT_DATA = [
			{ id: 'pj01', type_zh: '網站設計 + 品牌識別', type_en: 'Web Design + Brand Identity', title_zh: '大將開發', title_en: 'Tajiang Re-Branding and Website Design', client_zh: '', client_en: '', scope_zh: '房地產品牌重塑。', scope_en: 'Real estate re-branding.', services_zh: ['網站設計'], services_en: ['Web Design'], hero: 'images/pj_1.webp', imgs: [] },
			// ... more projects
		];

		const overlay = document.getElementById('pjOverlay');
		const modal = document.getElementById('pjModal');
		const closeBtn = document.getElementById('pjClose');
		const content = document.getElementById('pjContent');

		function renderCards() {
			const grid = document.getElementById('workGrid');
			if (!grid) return;
			const lng = document.documentElement.getAttribute('data-lang') || 'zh';
			PROJECT_DATA.forEach((p, i) => {
				const card = document.createElement('div');
				card.className = 'work-card reveal';
				card.innerHTML = `<div class="work-card-thumb" style="background-image: url('${p.hero}');"></div><div class="work-card-body"><div class="work-card-name">${lng === 'zh' ? p.title_zh : p.title_en}</div></div>`;
				card.addEventListener('click', () => openProject(i));
				grid.appendChild(card);
			});
		}

		function openProject(i) {
			const p = PROJECT_DATA[i];
			content.innerHTML = `<h2>${p.title_en}</h2><img src="${p.hero}" style="width:100%">`;
			overlay.classList.add('open');
			modal.classList.add('open');
		}

		closeBtn?.addEventListener('click', () => {
			overlay.classList.remove('open');
			modal.classList.remove('open');
		});

		renderCards();
	</script>
</Layout>
