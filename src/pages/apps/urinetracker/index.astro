---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Urine Tracker — Private Voiding Diary | Studio Zinc">
	<Navbar />

	<div class="page-wrap">
		<!-- APP HERO -->
		<section class="app-hero">
			<div class="grid-bg"></div>
			<div class="lava-bg">
				<div class="lava-1"></div>
				<div class="lava-2"></div>
			</div>

			<div class="app-hero-content">
				<div class="app-hero-left">
					<div class="app-hero-eyebrow">Studio Zinc · Android App</div>
					<h1>Urine<br><em>Tracker</em></h1>
					<p class="app-hero-desc">A calm, private voiding log. Track your urination events and fluid intake quietly and locally. Can export data and perform simple analytics for you to show your urologist. It's Urine Nice.</p>

					<div class="app-hero-actions">
						<a href="#" class="play-badge" id="playStoreBadge">
							<svg viewBox="0 0 24 24" fill="currentColor">
								<path d="M3 20.5v-17c0-.83.94-1.3 1.6-.8l14 8.5c.62.38.62 1.22 0 1.6l-14 8.5C3.94 21.8 3 21.33 3 20.5z" />
							</svg>
							Get it on Google Play
						</a>
						<a href="support" class="btn-outline">Support</a>
					</div>

					<div class="trust-row">
						<div class="trust-pill"><span class="tp-icon">🔒</span> No Account</div>
						<div class="trust-pill"><span class="tp-icon">📵</span> No Internet Required</div>
						<div class="trust-pill"><span class="tp-icon">🚫</span> No Ads</div>
						<div class="trust-pill"><span class="tp-icon">💾</span> 100% Local Storage</div>
					</div>
				</div>

				<div class="app-hero-right">
					<div class="phone-glow"></div>
					<div class="phone-mockup">
						<div class="phone-screen">
							<div class="ps-status"><span>9:41</span><span>● ● ▮</span></div>
							<div class="ps-header">Urine Tracker</div>
							<div class="ps-sub">Today — April 1</div>
							<div class="ps-big-num">1,450</div>
							<div class="ps-big-unit">ml logged today</div>
							<div class="ps-bar-wrap"><div class="ps-bar-fill"></div></div>
							<div class="ps-log-row"><div class="ps-log-dot"></div><div class="ps-log-text">Intake · 8:15 AM</div><div class="ps-log-amount">250ml</div></div>
							<div class="ps-log-row"><div class="ps-log-dot"></div><div class="ps-log-text">Coffee · 10:30 AM</div><div class="ps-log-amount">200ml</div></div>
							<div class="ps-log-row"><div class="ps-log-dot"></div><div class="ps-log-text">Water · 12:00 PM</div><div class="ps-log-amount">500ml</div></div>
							<div class="ps-log-row"><div class="ps-log-dot"></div><div class="ps-log-text">Tea · 2:45 PM</div><div class="ps-log-amount">300ml</div></div>
							<div class="ps-log-row"><div class="ps-log-dot"></div><div class="ps-log-text">Water · 4:10 PM</div><div class="ps-log-amount">200ml</div></div>
							<div class="ps-add-btn">+ LOG DRINK</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features-section">
			<div class="section-eyebrow reveal">Features</div>
			<div class="features-grid">
				<div class="feature-card reveal">
					<div class="feature-n">01</div>
					<div class="feature-icon">⏱️</div>
					<div class="feature-name">Track Your Stream</div>
					<div class="feature-desc">Time your urination duration with a single button. Easily add notes, urgency, pain, or leak tags.</div>
				</div>
				<div class="feature-card reveal">
					<div class="feature-n">02</div>
					<div class="feature-icon">📄</div>
					<div class="feature-name">Export for Doctors</div>
					<div class="feature-desc">Generate clinical-grade PDF reports of your voiding diary to share with your urologist.</div>
				</div>
				<div class="feature-card reveal">
					<div class="feature-n">03</div>
					<div class="feature-icon">💧</div>
					<div class="feature-name">Hydration Context</div>
					<div class="feature-desc">Optionally track your fluid intake alongside your output to see the full picture.</div>
				</div>
				<div class="feature-card reveal">
					<div class="feature-n">04</div>
					<div class="feature-icon">📊</div>
					<div class="feature-name">Rich Analytics</div>
					<div class="feature-desc">View heatmaps of your bathroom habits, daily frequencies, and trends over time.</div>
				</div>
				<div class="feature-card reveal">
					<div class="feature-n">05</div>
					<div class="feature-icon">✨</div>
					<div class="feature-name">Premium Themes</div>
					<div class="feature-desc">Choose from Dark, Light, or a special 'Golden' theme with glitter to celebrate your logs.</div>
				</div>
				<div class="feature-card reveal">
					<div class="feature-n">06</div>
					<div class="feature-icon">🔒</div>
					<div class="feature-name">Totally Private</div>
					<div class="feature-desc">All health data stays on your device. 100% Privacy.</div>
				</div>
			</div>
		</section>

		<!-- DISCLAIMER -->
		<div class="disclaimer-section">
			<div class="disclaimer-inner">
				<div class="disclaimer-label">Medical Disclaimer</div>
				<p class="disclaimer-text">
					<strong>Urine Tracker is a personal logging tool only.</strong>
					It is not a medical device and does not provide medical advice, diagnoses, or treatment recommendations.
					The information you record is for your own personal reference.
					If you have questions about your health, voiding habits, or any medical condition,
					please consult a qualified healthcare professional.
					Do not rely on this app to make medical decisions.
				</p>
			</div>
		</div>

		<!-- LINKS SECTION -->
		<section class="app-links-section">
			<div class="app-links-heading reveal">Legal &amp; Support</div>
			<div class="app-links-grid">
				<a href="privacy" class="btn-primary">Privacy Policy</a>
				<a href="support" class="btn-outline">Support &amp; FAQ</a>
			</div>
			<p style="font-size:.85rem; color: var(--fg2); line-height:1.7; max-width:520px;">
				Questions about the app? Found a bug? Check the support page or reach out directly at
				<a href="mailto:hello@studiozinc.com" style="color:var(--cyan);">hello@studiozinc.com</a>.
			</p>
		</section>

		<Footer />
	</div>

	<style>
		/* Include the app specific CSS from apps.css / inline styles here */
		@import "/apps.css";
		/* Or move to global if needed */
	</style>
</Layout>
