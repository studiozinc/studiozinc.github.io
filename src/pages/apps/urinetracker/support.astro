---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
---

<Layout title="Support — Urine Tracker | Studio Zinc">
	<Navbar />

	<div class="page-wrap">
		<!-- HERO -->
		<div class="support-hero">
			<div class="support-hero-content">
				<div class="support-eyebrow">Urine Tracker · Studio Zinc</div>
				<h1>Support &amp; FAQ</h1>
				<p>Find answers to common questions below. If you're still stuck, reach out directly — we're a small team and we actually read every message.</p>
			</div>
		</div>

		<!-- CONTACT STRIP -->
		<div class="contact-strip">
			<div class="contact-strip-inner">
				<div class="contact-strip-left">
					<h2>Can't find what you need?</h2>
					<p>Email us directly: <a href="mailto:hello@studiozinc.com">hello@studiozinc.com</a><br>
						We aim to reply within 5 business days (GMT+8).</p>
				</div>
				<a href="mailto:hello@studiozinc.com?subject=Urine Tracker Support" class="btn-cyan">Email Support</a>
			</div>
		</div>

		<div class="support-body">
			<!-- FAQ -->
			<div class="faq-section-label reveal">Frequently Asked Questions</div>
			<div class="faq-list">
				<details class="faq-item reveal">
					<summary class="faq-q">How do I log a stream?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Press and hold the large button on the tracker screen to time your urination duration. When finished, you can optionally rate the color, add symptoms like urgency or pain, and attach an image.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Can I set a custom daily goal?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Yes. Go to <strong>Settings → Daily Goal</strong> and enter the volume that works for you. The progress bar on the main screen will update to reflect your target. We do not suggest or impose any default target — your goal is yours to decide.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Can I log my fluid intake too?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Yes, tracking hydration context is helpful for a complete voiding diary. You can use the quick-add buttons or watch app to log drink intake alongside your urine output.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Can I delete a log entry?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Yes. On the main screen, long-press any log entry to reveal a delete option, or swipe left on the entry. Deleted entries cannot be recovered.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Does the app sync across devices?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">No — and that's intentional. All data stays on your device only. There is no cloud sync, no account, and no cross-device backup through our system. This is a core privacy decision, not a missing feature.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Will I lose my data if I uninstall the app?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Yes. Uninstalling the app removes all locally stored data. If your device uses Android Auto Backup (a Google system feature), some data may be included in your device backup — but this is handled by Google, not by us.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Does the app require an internet connection?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">No. Urine Tracker works completely offline. It never connects to the internet and requires no internet permission at the system level.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">I found a bug. How do I report it?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Please email <a href="mailto:hello@studiozinc.com?subject=Urine Tracker Bug Report">hello@studiozinc.com</a> with the subject line "Urine Tracker Bug Report." Include your Android version, device model, and a description of what happened. Screenshots are always helpful.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Can I share my logs with a doctor?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">Yes. Navigate to your Stats screen and use the PDF export tool to generate a clear, clinical-grade voiding diary report covering your chosen date range. You can print this or email it directly to your urologist.</p>
				</details>
				<details class="faq-item reveal">
					<summary class="faq-q">Is this app a medical tool?<span class="faq-arrow">+</span></summary>
					<p class="faq-answer">No. Urine Tracker is a personal logging utility for your own reference. It is not a medical device and does not provide medical advice or recommendations. Always consult a healthcare professional for guidance about your health or fluid intake needs. See our full <a href="privacy">Privacy Policy</a> for details.</p>
				</details>
			</div>

			<!-- TIPS -->
			<div class="tips-section">
				<div class="faq-section-label reveal">Quick Tips</div>
				<div class="tips-grid">
					<div class="tip-card reveal">
						<div class="tip-icon">⚡</div>
						<div class="tip-title">Watch Companion</div>
						<div class="tip-text">Use the companion smartwatch app (if installed) to conveniently log your output and intake directly from your wrist.</div>
					</div>
					<div class="tip-card reveal">
						<div class="tip-icon">📅</div>
						<div class="tip-title">View Past Days</div>
						<div class="tip-text">Swipe left on the date heading to browse previous days' logs and track your patterns over time.</div>
					</div>
					<div class="tip-card reveal">
						<div class="tip-icon">🌓</div>
						<div class="tip-title">Dark Mode</div>
						<div class="tip-text">The app follows your system theme by default. You can override this in Settings → Appearance.</div>
					</div>
					<div class="tip-card reveal">
						<div class="tip-icon">🗑️</div>
						<div class="tip-title">Clear Today's Log</div>
						<div class="tip-text">To start fresh, go to Settings → Clear Today's Data. This affects only the current day.</div>
					</div>
				</div>
			</div>

			<!-- RESPONSE NOTE -->
			<div class="response-note reveal">
				<div class="response-note-icon">📬</div>
				<div class="response-note-text">
					<strong>It's just me and my coding agent here.</strong> Emails are read and answered personally. Typically within 5 business days (Monday–Friday, GMT+8). We do not use automated support ticketing systems.
				</div>
			</div>
		</div>

		<Footer />
	</div>

	<style>
		@import "/apps.css";
		.support-hero {
			position: relative;
			padding: 5rem 2.5rem 3.5rem;
			border-bottom: 1px solid var(--border);
			overflow: hidden;
		}
		.support-hero-content {
			position: relative;
			z-index: 2;
			max-width: 760px;
		}
		.support-hero h1 {
			font-family: 'Unbounded', sans-serif;
			font-weight: 900;
			font-size: clamp(1.8rem, 4vw, 2.8rem);
			letter-spacing: -.03em;
			color: var(--fg);
			line-height: 1.2;
			margin-bottom: .75rem;
		}
		.contact-strip {
			background: var(--surface);
			border-bottom: 1px solid var(--border);
			transition: background .4s;
		}
		.contact-strip-inner {
			max-width: 900px;
			margin: 0 auto;
			padding: 2.5rem 2.5rem;
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 2rem;
			flex-wrap: wrap;
		}
		.support-body {
			max-width: 900px;
			margin: 0 auto;
			padding: 4rem 2.5rem 6rem;
		}
		@media (max-width: 768px) {
			.support-hero {
				padding: 4rem 1.25rem 2.5rem;
			}
			.contact-strip-inner {
				padding: 2rem 1.25rem;
			}
			.support-body {
				padding: 3rem 1.25rem 5rem;
			}
		}
	</style>
</Layout>
